generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client" // 🛡️ Local output bypass
  engineType    = "library"
  binaryTargets = ["native", "windows", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_LEGAL")
}

model ProductA {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  serialNumber   String   @unique @map("serial_number") 
  priceHT        Decimal  @map("price_ht") @db.Decimal(10, 2)      
  purchaseCost   Decimal  @default(0) @map("purchase_cost") @db.Decimal(10, 2) 
  vatRate        Decimal  @default(0.20) @map("vat_rate") @db.Decimal(4, 2)
  quantity       Decimal  @default(0) @db.Decimal(10, 2)
  measureUnit    String   @default("UNIT") 
  technicalSpecs String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("products_legal")
}

model ClientA {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  ice       String?  @unique @db.VarChar(50) 
  rc        String?  @db.VarChar(50)
  if        String?  @db.VarChar(50) 
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  phone     String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  invoices  Invoice[]
  @@map("clients_legal")
  @@index([ice])
  @@index([name])
}

model Invoice {
  id        String   @id @default(uuid())
  reference String   @unique
  legacyReference String? @map("legacy_reference")

  clientId  String?  @map("client_id")
  client    ClientA? @relation(fields: [clientId], references: [id])
  
  status    String   @default("EN_ATTENTE") 
  type      String   @default("FACTURE")      
  
  totalHT      Decimal  @db.Decimal(12, 2)
  totalTTC     Decimal  @db.Decimal(12, 2)
  amountPaid   Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)

  note         String?  @db.Text

  // 🛡️ BIG DATA AUDIT: Full Legal Snapshots
  clientNameSnapshot    String? @map("client_name_snapshot")
  clientIceSnapshot     String? @map("client_ice_snapshot")
  clientRcSnapshot      String? @map("client_rc_snapshot") 
  clientIfSnapshot      String? @map("client_if_snapshot") 
  clientAddressSnapshot String? @map("client_address_snapshot")

  items     InvoiceItem[]
  payments  Payment[]
  
  issuedAt  DateTime @default(now())

  @@map("invoices")
  @@index([issuedAt, status]) // ⚡ Composite index to instantly fetch legal revenues
  @@index([clientId])
}

model InvoiceItem {
  id         String  @id @default(uuid())
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId  String? @map("product_id") 
  productName String
  quantity    Decimal @db.Decimal(10, 2)
  unitPriceHT Decimal @db.Decimal(10, 2)
  unitPurchaseCostSnapshot Decimal @default(0) @map("unit_purchase_cost_snapshot") @db.Decimal(10, 2)
  vatRateSnapshot          Decimal @default(0.20) @map("vat_rate_snapshot") @db.Decimal(4, 2)
  measureUnit    String?  @map("measure_unit")
  technicalSpecs String?  @map("technical_specs")
  @@map("invoice_items")
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  method    String   
  reference String?  
  note      String?
  paidAt    DateTime @default(now()) @map("paid_at")
  
  @@map("payments_legal")
  @@index([paidAt]) // ⚡ Instantly calculate Legal Treasury
}

model InvoiceSequence {
  year      Int      @id
  lastCount Int      @default(0)
  @@map("invoice_sequences")
}

model QuoteSequence {
  year      Int      @id
  lastCount Int      @default(0)
  @@map("quote_sequences")
}

model CompanySettings {
  id        String   @id @default("1")
  name      String   @default("MA SOCIETE")
  ice       String?
  address   String?
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  updatedAt DateTime @updatedAt
  @@map("company_settings")
}
// 1. UPDATE YOUR SUPPLIER MODEL (Just add the purchases array)
model SupplierA {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  contactName String?  @map("contact_name") @db.VarChar(255)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  address     String?  @db.Text
  
  ice         String?  @unique @db.VarChar(50) 
  rc          String?  @db.VarChar(50)
  if          String?  @db.VarChar(50) 
  patente     String?  @db.VarChar(50)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 🛑 ADD THIS LINE: Links the supplier to their invoices
  purchases   PurchaseInvoice[] 

  @@map("suppliers_legal")
  @@index([ice])
  @@index([name])
}

// 2. ADD THE NEW PURCHASE INVOICE MODEL
model PurchaseInvoice {
  id              String   @id @default(uuid())
  reference       String   @unique // e.g., "BC-2026-001" or the Supplier's actual Invoice Number
  
  supplierId      String   @map("supplier_id")
  supplier        SupplierA @relation(fields: [supplierId], references: [id])
  
  status          String   @default("EN_ATTENTE") // EN_ATTENTE, VALIDEE, PAYEE, ANNULEE
  type            String   @default("FACTURE_ACHAT") // BON_COMMANDE, BON_RECEPTION, FACTURE_ACHAT
  
  totalHT         Decimal  @db.Decimal(12, 2)
  totalTTC        Decimal  @db.Decimal(12, 2)
  amountPaid      Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)

  note            String?  @db.Text
  
  // Snapshots for legal archiving (if the supplier changes their name later)
  supplierNameSnapshot String? @map("supplier_name_snapshot")
  supplierIceSnapshot  String? @map("supplier_ice_snapshot")

  items           PurchaseItem[]
  
  issuedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("purchase_invoices")
  @@index([issuedAt, status])
  @@index([supplierId])
}

// 3. ADD THE PURCHASE ITEMS MODEL (What exactly did you buy?)
model PurchaseItem {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId       String?  @map("product_id") // Links to your ProductA if you track specific legal products
  productName     String
  
  quantity        Decimal  @db.Decimal(10, 2)
  unitPriceHT     Decimal  @db.Decimal(10, 2)
  vatRateSnapshot Decimal  @default(0.20) @map("vat_rate_snapshot") @db.Decimal(4, 2)
  
  @@map("purchase_items")
}