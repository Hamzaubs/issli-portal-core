// packages/db-internal/prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client" // 🛡️ Local output bypass
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_INTERNAL")
}

model ProductB {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  internalSku    String   @unique @map("internal_sku") @db.VarChar(50)
  
  purchaseCost   Decimal  @map("purchase_cost") @db.Decimal(10, 2)
  
  // ✅ TVA Implementation (Master ERP Analytics)
  priceHT        Decimal  @default(0) @map("price_ht") @db.Decimal(10, 2)
  vatRate        Decimal  @default(0) @map("vat_rate") @db.Decimal(4, 2) // e.g., 0.20, 0.10, 0.00
  priceTTC       Decimal  @default(0) @map("price_ttc") @db.Decimal(10, 2)
  
  quantity       Int      @default(0)
  measureUnit    String   @default("UNIT") 
  technicalSpecs String?  @map("technical_specs")
  
  movements      StockMovement[]

  @@map("products_internal")
}

model ClientB {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  
  // ✅ Synchronization Keys (Required to link with Silo A)
  phone     String?  @db.VarChar(50)
  ice       String?  @db.VarChar(50)
  address   String?  @db.Text
  city      String?  @db.VarChar(100)

  category  String   @default("STANDARD")
  notes     String?  @db.Text
  
  // Financials
  totalSpent Decimal  @default(0) @map("total_spent") @db.Decimal(10, 2)
  balance    Decimal  @default(0) @db.Decimal(10, 2) // Positive = Client owes us

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  movements  StockMovement[]

  @@map("clients_internal")
  @@index([name])
  @@index([phone])
  @@index([ice])
  @@index([balance]) // ⚡ Instantly speeds up "Top Debtors" calculations
}

model StockMovement {
  id               String   @id @default(uuid())
  batchId          String?  @map("batch_id")
  
  // Relationships
  productId        String   @map("product_id")
  product          ProductB @relation(fields: [productId], references: [id])

  clientId         String?  @map("client_id")
  client           ClientB? @relation(fields: [clientId], references: [id])

  // ✅ New Relationship: Links movement to a Supplier for payments and restocks
  supplierId       String?  @map("supplier_id")
  supplier         SupplierB? @relation(fields: [supplierId], references: [id])

  userId           String?  @map("user_id")
  user             User?    @relation(fields: [userId], references: [id])

  // Core Data
  quantity         Int
  returnedQuantity Int      @default(0) @map("returned_quantity") // ✅ FIX: Added to track partial/full returns
  type             MovementType
  
  // ✅ Financial Data (Now with TVA Math)
  totalHT          Decimal?       @map("total_ht") @db.Decimal(10, 2)
  totalTVA         Decimal?       @map("total_tva") @db.Decimal(10, 2)
  amount           Decimal?       @db.Decimal(10, 2) // Remains as Total TTC for legacy compatibility and Exact Due math
  paidAmount       Decimal        @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paymentMethod    String?        @default("CASH")
  paymentRef       String?        // ✅ Native column for Checks/Transfers

  // ✅ Snapshots for Analytics & Audit Safety
  snapshotPurchaseCost Decimal? @map("snapshot_purchase_cost") @db.Decimal(10, 2)
  snapshotPriceHT      Decimal? @map("snapshot_price_ht") @db.Decimal(10, 2)
  snapshotVatRate      Decimal? @map("snapshot_vat_rate") @db.Decimal(4, 2)
  snapshotPriceTTC     Decimal? @map("snapshot_price_ttc") @db.Decimal(10, 2)
  snapshotProductName  String?  @map("snapshot_product_name") @db.VarChar(255)
  
  createdAt        DateTime       @default(now()) @map("created_at") 
  
  @@map("movements_internal")
  @@index([batchId]) // ⚡ Fast grouping for documents
  @@index([createdAt, type]) // ⚡ Composite index for lightning-fast Dashboard charts
  @@index([productId])
  @@index([clientId])
  @@index([supplierId]) // ⚡ Speeds up Supplier history loading
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String    
  role      UserRole  @default(POS_USER) 
  movements StockMovement[]

  @@map("users_internal")
}

enum UserRole {
  SUPER_ADMIN 
  LEGAL_USER
  POS_USER        
}

enum MovementType {
  SALE_CASH
  SALE_CREDIT 
  RESTOCK
  ADJUSTMENT
  RETURN 
  QUOTE
  PAYMENT     // ✅ Standardized Payment Type
}

// 1. THE INTERNAL SUPPLIERS (SILO B)
model SupplierB {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  contactName String?  @map("contact_name") @db.VarChar(255)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  address     String?  @db.Text
  
  // Internal reference for Moroccan tax IDs if needed
  ice         String?  @unique @db.VarChar(50) 
  rc          String?  @db.VarChar(50)
  if          String?  @db.VarChar(50) 
  patente     String?  @db.VarChar(50)

  // ✅ New Financials (Accounts Payable)
  totalPurchased Decimal  @default(0) @map("total_purchased") @db.Decimal(10, 2)
  balance        Decimal  @default(0) @db.Decimal(10, 2) // Positive = We owe them money

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchases   PurchaseB[] 
  movements   StockMovement[] // ✅ Links standalone payments to the supplier

  @@map("suppliers_internal")
  @@index([ice])
  @@index([name])
  @@index([balance]) // ⚡ Instantly speeds up "Top Creditors" queries
}

// 2. THE INTERNAL PURCHASES (SILO B)
model PurchaseB {
  id              String   @id @default(uuid())
  reference       String   @unique // Internal ID or Supplier's Ref
  
  supplierId      String   @map("supplier_id")
  supplier        SupplierB @relation(fields: [supplierId], references: [id])
  
  status          String   @default("EN_ATTENTE") // EN_ATTENTE, VALIDEE, PAYEE
  type            String   @default("FACTURE_ACHAT") // BON_COMMANDE, FACTURE_ACHAT
  
  totalHT         Decimal  @db.Decimal(12, 2)
  totalTTC        Decimal  @db.Decimal(12, 2)
  amountPaid      Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)

  note            String?  @db.Text
  
  // Snapshots for truth-tracking
  supplierNameSnapshot String? @map("supplier_name_snapshot")
  supplierIceSnapshot  String? @map("supplier_ice_snapshot")

  items           PurchaseItemB[]
  
  issuedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("purchase_invoices_internal")
  @@index([issuedAt, status])
  @@index([supplierId])
}

// 3. THE INTERNAL PURCHASE ITEMS (SILO B)
model PurchaseItemB {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         PurchaseB @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId       String?  @map("product_id") 
  productName     String
  
  quantity        Decimal  @db.Decimal(10, 2)
  unitPriceHT     Decimal  @db.Decimal(10, 2)
  vatRateSnapshot Decimal  @default(0.20) @map("vat_rate_snapshot") @db.Decimal(4, 2)
  
  @@map("purchase_items_internal")
}