{
  "name": "marine-ops-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "web-ui"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "db:generate": "npm run generate --workspaces --if-present",
    "db:push": "npm run push --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @marine/api",
    "dev:web": "npm run dev -w web-ui"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "prisma": "5.10.2"
  }
}
