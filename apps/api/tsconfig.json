{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "../..", 
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@marine/db-internal": ["../../packages/db-internal/src/index.ts"],
      "@marine/db-legal": ["../../packages/db-legal/src/index.ts"],
      "@marine/shared-types": ["../../packages/shared-types/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}