// packages/db-legal/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@marine/db-legal"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_LEGAL")
}

// ==========================================
// 📦 PRODUCTS (Inventory & Margin Base)
// ==========================================
model ProductA {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(255)
  serialNumber   String   @unique @map("serial_number") 
  
  // Financials
  priceHT        Decimal  @map("price_ht") @db.Decimal(10, 2)      
  purchaseCost   Decimal  @default(0) @map("purchase_cost") @db.Decimal(10, 2) 
  vatRate        Decimal  @default(0.20) @map("vat_rate") @db.Decimal(4, 2)
  
  // Stock
  quantity       Int      @default(0)
  measureUnit    String   @default("UNIT") 
  technicalSpecs String?  

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("products_legal")
}

model ClientA {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  ice       String?  @db.VarChar(50) 
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  phone     String?  @db.VarChar(50)
  
  createdAt DateTime @default(now()) @map("created_at")
  invoices  Invoice[]

  @@map("clients_legal")
  @@index([ice])
}

model Invoice {
  id        String   @id @default(uuid())
  reference String   @unique
  
  // ✅ THIS IS THE MISSING FIELD causing the error
  legacyReference String? @map("legacy_reference")

  clientId  String?  @map("client_id")
  client    ClientA? @relation(fields: [clientId], references: [id])
  
  status    String   @default("EN_ATTENTE") 
  type      String   @default("FACTURE")    
  
  totalHT    Decimal  @db.Decimal(12, 2)
  totalTTC   Decimal  @db.Decimal(12, 2)
  amountPaid Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)

  note       String?  @db.Text

  clientNameSnapshot    String? @map("client_name_snapshot")
  clientIceSnapshot     String? @map("client_ice_snapshot")
  clientAddressSnapshot String? @map("client_address_snapshot")

  items     InvoiceItem[]
  payments  Payment[]
  
  issuedAt  DateTime @default(now())

  @@index([issuedAt])
  @@index([status])
  @@index([clientId])

  @@map("invoices")
}

model InvoiceItem {
  id         String  @id @default(uuid())
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId  String? @map("product_id") 
  
  productName String
  quantity    Int
  unitPriceHT Decimal @db.Decimal(10, 2)
  
  unitPurchaseCostSnapshot Decimal @default(0) @map("unit_purchase_cost_snapshot") @db.Decimal(10, 2)
  vatRateSnapshot          Decimal @default(0.20) @map("vat_rate_snapshot") @db.Decimal(4, 2)

  measureUnit    String?  @map("measure_unit")
  technicalSpecs String?  @map("technical_specs")

  @@map("invoice_items")
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String   @map("invoice_id")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  amount    Decimal  @db.Decimal(12, 2)
  method    String   
  reference String?  
  note      String?
  
  paidAt    DateTime @default(now()) @map("paid_at")
  
  @@index([paidAt])

  @@map("payments_legal")
}

model InvoiceSequence {
  year      Int     @id
  lastCount Int     @default(0)
  @@map("invoice_sequences")
}

model QuoteSequence {
  year      Int     @id
  lastCount Int     @default(0)
  @@map("quote_sequences")
}

model CompanySettings {
  id        String   @id @default("1")
  name      String   @default("MA SOCIETE")
  ice       String?
  address   String?
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  
  updatedAt DateTime @updatedAt
  @@map("company_settings")
}